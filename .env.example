# 环境变量配置文件
# 复制此文件为 .env 并填写实际值

# 服务器配置
PORT=3000
NODE_ENV=development

# 管理后台安全
ADMIN_API_KEY=your-secure-api-key-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure-password-here

# 邮件服务配置（可选）
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Wanderlust Adventures <your-email@gmail.com>
EMAIL_TO=your-personal-email@gmail.com

# 数据库配置（如果使用数据库）
DATABASE_URL=postgresql://username:password@localhost:5432/wanderlust_db

# 第三方服务（可选）
FORMSPREEE_FORM_ID=your-formspree-id
TIDIO_CHAT_KEY=your-tidio-key
DISQUS_SHORTNAME=your-disqus-shortname
CALENDLY_USERNAME=your-calendly-username

# 安全配置
SESSION_SECRET=your-session-secret-key
CORS_ORIGIN=http://localhost:3000

# 功能开关
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_FILE_UPLOADS=false